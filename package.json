{
	"name": "pi-cmdr",
	"version": "0.1.0",
	"type": "module",
	"description": "Command picker extension for the Pi coding agent.",
	"keywords": [
		"pi",
		"pi-package",
		"pi-coding-agent",
		"extension",
		"command-palette"
	],
	"scripts": {
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"format": "biome format --write .",
		"check": "npm run typecheck && npm run lint"
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@mariozechner/pi-coding-agent": "^0.70.0",
		"@mariozechner/pi-tui": "^0.70.0",
		"@types/node": "^25.6.0",
		"typescript": "^6.0.2"
	},
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"license": "MIT",
	"author": "mfmezger",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mfmezger/pi-cmdr.git"
	},
	"homepage": "https://github.com/mfmezger/pi-cmdr#readme",
	"bugs": {
		"url": "https://github.com/mfmezger/pi-cmdr/issues"
	},
	"files": [
		"README.md",
		"LICENSE",
		"src",
		"examples"
	],
	"dependencies": {
		"yaml": "^2.8.3"
	}
}
